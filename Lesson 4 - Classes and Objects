using namespace std;

class Person{
    public: 
    string name {"Bobby"};
    int age{18};
    char gender {'M'};
    
    public:
    void intro(){
        cout << "Enter your gender: ";
        cin >> gender;
        
        cout << "Hello! My name is " << name << ". I am " << age << " y/o." << endl;
        
        if(gender == 'M'){
            cout << " I am a Male." << endl;
        }
        else if(gender == 'F'){
            cout << " I am a Female." << endl;
        }
        else{
            cout << "Gender Unknown" << endl;
        }
    }
};

