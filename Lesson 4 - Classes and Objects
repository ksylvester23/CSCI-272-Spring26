using namespace std;
class Dog{
    private: //Can only be accessed within this class
    string breed;
    string color;
    int age;
    
    public: //Can be accessed anywhere
    Dog(string b, string c, int a){
        breed = b;
        color = c; 
        age = a;
    }
    void showInfo(){
        cout << "Breed: " << breed << "  |  Color: " << color << "  |  Age: " << age << "y/o" << endl;
    }
};

