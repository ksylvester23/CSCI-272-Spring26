using namespace std;

class Car{
    
    private:
    string brand{"Nissan"};
    string model{"Altima"};
    int year{2017};
    
    public:
    Car(){ //this is the default constructor 
    }
    Car(string b, string m, int y){ //the parameterized constructor
        brand = b;
        model = m;
        year = y;
    }
    Car(const Car &other){ //this is the copy constructor
    brand = other.brand;
    model = other.model;
    year = other.year;
    }
    void startEngine(){
     cout << brand << " " << model << " " << year << " started Engine" << endl;
          }  
    };

